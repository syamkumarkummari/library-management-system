<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen">

<h1 class="text-3xl font-bold mb-8 text-white flex items-center gap-2">
  ✏️ Edit Book
</h1>

<form action="/books/update/<%= book.id %>" method="POST"
class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl space-y-5 w-96 shadow-2xl">

  <!-- Book Name -->
  <div>
    <label class="block text-sm text-white/70 mb-1">Book Name</label>
    <input name="book_name" value="<%= book.book_name %>"
      class="w-full p-3 rounded-lg bg-white/10 text-white outline-none border border-white/10 focus:ring-2 focus:ring-purple-400">
  </div>

  <!-- Author -->
  <div>
    <label class="block text-sm text-white/70 mb-1">Author</label>
    <input name="author" value="<%= book.author %>"
      class="w-full p-3 rounded-lg bg-white/10 text-white outline-none border border-white/10 focus:ring-2 focus:ring-purple-400">
  </div>

  <!-- Quantity -->
  <div>
    <label class="block text-sm text-white/70 mb-1">Quantity</label>
    <input name="quantity" value="<%= book.quantity %>"
      class="w-full p-3 rounded-lg bg-white/10 text-white outline-none border border-white/10 focus:ring-2 focus:ring-blue-400">
  </div>

  <!-- Image URL -->
  <div>
    <label class="block text-sm text-white/70 mb-1">Image URL</label>
    <input name="image" value="<%= book.image %>"
      class="w-full p-3 rounded-lg bg-white/10 text-white outline-none border border-white/10 focus:ring-2 focus:ring-indigo-400">
  </div>

  <!-- Button -->
  <button
    class="w-full bg-gradient-to-r from-purple-500 to-blue-500 p-3 rounded-xl text-white font-semibold
           hover:scale-105 hover:shadow-lg transition duration-300">
    Update Book
  </button>

</form>

</div>
</div>

<%- include('partials/footer') %>