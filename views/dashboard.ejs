<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-6 w-full min-h-screen bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<!-- TITLE -->
<h1 class="text-3xl font-bold mb-6 flex items-center gap-2">
  📚 Library Dashboard
</h1>

<!-- 🔥 STATS (UPDATED TO 5 CARDS) -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-10">

  <!-- TOTAL BOOKS -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 text-center shadow-lg">
    <p class="text-white/70">Total Books</p>
    <p class="text-4xl font-bold"><%= totalBooks %></p>
  </div>

  <!-- ISSUED -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 text-center shadow-lg">
    <p class="text-white/70">Issued</p>
    <p class="text-4xl font-bold text-yellow-400"><%= issued %></p>
  </div>

  <!-- AVAILABLE -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 text-center shadow-lg">
    <p class="text-white/70">Available</p>
    <p class="text-4xl font-bold text-green-400"><%= available %></p>
  </div>

  <!-- 👥 TOTAL USERS -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 text-center shadow-lg">
    <p class="text-white/70">Users</p>
    <p class="text-4xl font-bold text-blue-400"><%= totalUsers %></p>
  </div>

  <!-- ⏰ OVERDUE -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 text-center shadow-lg">
    <p class="text-white/70">Overdue</p>
    <p class="text-4xl font-bold text-red-400"><%= overdue %></p>
  </div>

</div>

<!-- 📚 BOOKS GRID -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

<% books.forEach(book => { %>

<div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-4 text-center
            shadow-lg hover:shadow-[0_0_40px_rgba(139,92,246,0.6)]
            hover:scale-105 transform-gpu transition-all duration-300
            hover:border-purple-400 relative overflow-hidden group will-change-transform">

  <!-- ✨ Shine Effect -->
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent 
              translate-x-[-120%] group-hover:translate-x-[120%] 
              transition duration-700 pointer-events-none"></div>

  <!-- IMAGE -->
  <div class="overflow-hidden rounded-xl">
    <img src="<%= book.image || 'https://via.placeholder.com/300x400' %>" 
         loading="lazy"
         class="w-full aspect-[5/7] object-cover 
                transition-transform duration-500 
                group-hover:scale-110 will-change-transform">
  </div>

  <!-- BOOK NAME -->
  <h2 class="font-bold text-lg mt-3">
    <%= book.book_name %>
  </h2>

  <!-- AUTHOR -->
  <p class="text-white/60 text-sm">
    <%= book.author %>
  </p>

</div>

<% }) %>

</div>

</div>
</div>

<%- include('partials/footer') %>