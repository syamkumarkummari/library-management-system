<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      margin: 0;
      height: 100vh;
      overflow: hidden;
      font-family: sans-serif;
    }

    /* 🎥 Animated Background */
    .bg-animated {
      position: fixed;
      width: 100%;
      height: 100%;
      background: url('https://images.unsplash.com/photo-1512820790803-83ca734da794') no-repeat center center/cover;
      animation: zoomMove 20s ease-in-out infinite alternate;
      z-index: -2;
    }

    @keyframes zoomMove {
      0% { transform: scale(1); }
      100% { transform: scale(1.2); }
    }

    /* 🌫 Overlay */
    .overlay {
      position: fixed;
      width: 100%;
      height: 100%;
      background: rgba(15, 23, 42, 0.75);
      z-index: -1;
    }
  </style>
</head>

<body class="flex items-center justify-center">

<div class="bg-animated"></div>
<div class="overlay"></div>

<!-- 🔥 REGISTER CARD -->
<form action="/register" method="POST" 
      class="bg-white/10 backdrop-blur-2xl border border-white/20
             p-8 rounded-3xl shadow-[0_0_60px_rgba(0,0,0,0.8)]
             w-[400px] text-white space-y-4">

  <!-- Logo -->
  <h2 class="text-center text-xl font-bold tracking-wide text-white/90">
    📚 Library System
  </h2>

  <!-- Title -->
  <h3 class="text-center text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
    Create Account
  </h3>

  <!-- 👤 Full Name -->
  <input name="full_name" placeholder="Full Name"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-purple-500">

  <!-- 🎓 Register No -->
  <input name="reg_no" placeholder="Register Number"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-purple-500">

  <!-- 🏫 Department -->
  <input name="dept" placeholder="Department"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-purple-500">

  <!-- 📅 Academic Year -->
  <input name="year" placeholder="Academic Year (e.g. 3rd Year)"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-purple-500">

  <!-- 👤 Username -->
  <input name="username" placeholder="Username"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-blue-500">

  <!-- 🔐 Password -->
  <input name="password" type="password" placeholder="Password"
         class="w-full p-3 rounded-lg bg-white/10 border border-white/20 
                placeholder-white/60 text-white focus:ring-2 focus:ring-blue-500">


  <!-- 🚀 Button -->
  <button
    class="w-full p-3 rounded-lg font-semibold
           bg-gradient-to-r from-purple-500 to-blue-500
           hover:from-purple-600 hover:to-blue-600
           shadow-lg hover:shadow-purple-500/40 transition">
    Register
  </button>

  <!-- 🔁 Back -->
  <p class="text-center text-sm text-white/60">
    Already have an account?
    <a href="/" class="text-blue-400 hover:underline">Login</a>
  </p>

</form>

</body>
</html>