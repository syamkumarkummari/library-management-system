<div class="fixed w-64 h-full bg-[#0f172a] text-white p-5">

  <h1 class="text-2xl font-bold mb-8">📚 Library</h1>

  <ul class="space-y-3">

    <!-- DASHBOARD -->
    <li>
      <a href="<%= role === 'admin' ? '/dashboard' : '/user/dashboard' %>"
         class="block p-3 rounded-lg transition <%= current === 'dashboard' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        Dashboard
      </a>
    </li>

    <!-- BOOKS -->
    <li>
      <a href="/books"
         class="block p-3 rounded-lg transition <%= current === 'books' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        Books
      </a>
    </li>

    <% if (role === 'admin') { %>

    <!-- ISSUE -->
    <li>
      <a href="/issue"
         class="block p-3 rounded-lg transition <%= current === 'issue' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        Issue
      </a>
    </li>

    <!-- USER MANAGEMENT -->
    <li>
      <a href="/admin/users"
         class="block p-3 rounded-lg transition <%= current === 'users' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        User Management
      </a>
    </li>

    <% } %>

    <% if (role === 'user') { %>

    <!-- HISTORY -->
    <li>
      <a href="/user/history"
         class="block p-3 rounded-lg transition <%= current === 'history' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        History
      </a>
    </li>

    <!-- PROFILE -->
    <li>
      <a href="/user/profile"
         class="block p-3 rounded-lg transition <%= current === 'profile' ? 'bg-gradient-to-r from-purple-500 to-blue-500' : 'hover:bg-white/10' %>">
        My Profile
      </a>
    </li>

    <% } %>

    <!-- LOGOUT -->
    <li>
      <a href="/logout"
         class="block p-3 rounded-lg bg-red-500 hover:bg-red-600 text-center">
        Logout
      </a>
    </li>

  </ul>

</div>