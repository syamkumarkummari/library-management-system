<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<h1 class="text-3xl mb-6">📖 Book Details</h1>

<div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl p-6 flex gap-8 shadow-xl">

<img src="<%= book.image || 'https://via.placeholder.com/300x400' %>"
class="w-64 h-96 object-cover rounded-xl shadow-lg">

<div class="space-y-4">

<h2 class="text-2xl font-bold"><%= book.book_name %></h2>

<p class="text-white/70">✍ Author: <%= book.author %></p>

<p class="text-green-400">📦 Available: <%= book.quantity %></p>

<p>📍 Floor: 2nd Floor</p>
<p>📚 Shelf: A-12</p>

<p class="text-white/70">
This book is a valuable resource available in the library. You can find it easily using the floor and shelf information.
</p>

<a href="/user/books"
class="inline-block mt-4 bg-gradient-to-r from-purple-500 to-blue-500 px-6 py-2 rounded-lg">
← Back to Books
</a>

</div>

</div>

</div>
</div>

<%- include('partials/footer') %>