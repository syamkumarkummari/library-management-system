<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<!-- 🔥 SAME DARK BACKGROUND -->
<div class="ml-64 p-8 w-full min-h-screen 
     bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<h1 class="text-3xl font-bold mb-8 flex items-center gap-2">
  👤 My Dashboard
</h1>

<!-- 🔥 STATS CARDS -->
<div class="grid grid-cols-4 gap-6 mb-10">

  <!-- Total Borrowed -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 
              rounded-2xl p-6 text-center shadow-lg 
              hover:scale-105 transition duration-300">
    <p class="text-white/70">📚 Total Borrowed</p>
    <p class="text-3xl font-bold text-blue-400"><%= total %></p>
  </div>

  <!-- Currently Issued -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 
              rounded-2xl p-6 text-center shadow-lg 
              hover:scale-105 transition duration-300">
    <p class="text-white/70">📖 Currently Issued</p>
    <p class="text-3xl font-bold text-green-400"><%= issued %></p>
  </div>

  <!-- Overdue -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 
              rounded-2xl p-6 text-center shadow-lg 
              hover:scale-105 transition duration-300">
    <p class="text-white/70">⏰ Overdue</p>
    <p class="text-3xl font-bold text-red-400"><%= overdue %></p>
  </div>

  <!-- Fine -->
  <div class="bg-white/10 backdrop-blur-xl border border-white/20 
              rounded-2xl p-6 text-center shadow-lg 
              hover:scale-105 transition duration-300">
    <p class="text-white/70">💰 Fine</p>
    <p class="text-3xl font-bold text-purple-400">₹ <%= fine %></p>
  </div>

</div>

<!-- 📘 TABLE -->
<div class="bg-white/10 backdrop-blur-xl border border-white/20 
            rounded-2xl shadow-2xl overflow-hidden">

<h2 class="text-xl font-bold p-6">
  📖 My Issued Books
</h2>

<table class="w-full text-white">

<thead class="bg-gradient-to-r from-purple-500/30 to-blue-500/30">
<tr>
  <th class="p-4 text-left">Book</th>
  <th class="p-4 text-center">Qty</th>
  <th class="p-4 text-center">Issued</th>
  <th class="p-4 text-center">Due</th>
  <th class="p-4 text-center">Status</th>
</tr>
</thead>

<tbody>

<% issuedBooks.forEach(item => { %>
<tr class="border-b border-white/10 hover:bg-white/5 transition duration-200">

  <td class="p-4 font-semibold"><%= item.book_name %></td>

  <td class="p-4 text-center"><%= item.quantity %></td>

  <td class="p-4 text-center">
    <%= new Date(item.issue_date).toLocaleDateString('en-IN') %>
  </td>

  <td class="p-4 text-center">
    <%= item.due_date ? new Date(item.due_date).toLocaleDateString('en-IN') : '-' %>
  </td>

  <td class="p-4 text-center">
    <% 
      const today = new Date();
      const due = new Date(item.due_date);
    %>

    <% if (item.due_date && due < today) { %>
      <span class="px-3 py-1 rounded-full text-sm bg-red-500/20 text-red-300">
        Overdue
      </span>
    <% } else { %>
      <span class="px-3 py-1 rounded-full text-sm bg-green-500/20 text-green-300">
        Active
      </span>
    <% } %>
  </td>

</tr>
<% }) %>

</tbody>

</table>

</div>

</div>
</div>

<%- include('partials/footer') %>