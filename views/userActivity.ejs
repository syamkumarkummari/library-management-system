<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full text-white">

<h1 class="text-3xl font-bold mb-6">📊 User Activity</h1>

<!-- USER INFO -->
<div class="bg-white/10 p-6 rounded-2xl mb-8">
  <p><b>Name:</b> <%= user.full_name %></p>
  <p><b>Reg No:</b> <%= user.reg_no %></p>
  <p><b>Dept:</b> <%= user.dept %></p>
  <p><b>Year:</b> <%= user.year %></p>
</div>

<!-- TABLE -->
<div class="bg-white/10 rounded-2xl overflow-hidden">

<table class="w-full table-fixed text-white">

<thead class="bg-gradient-to-r from-purple-500/30 to-blue-500/30">
<tr class="text-left">
  <th class="p-4 w-[25%]">Book</th>
  <th class="w-[15%]">Issued</th>
  <th class="w-[15%]">Due</th>
  <th class="w-[15%]">Returned</th>
  <th class="w-[15%] text-center">Status</th>
  <th class="w-[15%] text-center">Fine</th>
</tr>
</thead>

<tbody>

<% activity.forEach(item => { %>
<tr class="border-b border-white/10 hover:bg-white/5">

<td class="p-4"><%= item.book_name %></td>

<td><%= new Date(item.issue_date).toLocaleDateString('en-IN') %></td>

<td>
<%= item.due_date ? new Date(item.due_date).toLocaleDateString('en-IN') : '-' %>
</td>

<td>
<%= item.return_date ? new Date(item.return_date).toLocaleDateString('en-IN') : '-' %>
</td>

<td class="text-center">
<% if(item.status === 'Returned'){ %>
<span class="text-green-400">Returned</span>
<% } else if(item.status === 'Overdue'){ %>
<span class="text-red-400">Overdue</span>
<% } else { %>
<span class="text-blue-400">Active</span>
<% } %>
</td>

<td class="text-center text-yellow-400 font-semibold">
₹ <%= item.fine %>
</td>

</tr>
<% }) %>

</tbody>
</table>

</div>