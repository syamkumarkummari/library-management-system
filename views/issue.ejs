<%- include('partials/header') %>

<div class="flex relative z-10">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen">

<h1 class="text-3xl font-bold mb-8 text-white flex items-center gap-2">
  🔄 Issue Books
</h1>

<!-- Issue Form -->
<form action="/issue/add" method="POST"
      class="bg-white/10 backdrop-blur-xl border border-white/20 
             p-6 rounded-2xl shadow-xl mb-8 grid grid-cols-4 gap-4">

  <!-- Student Name -->
  <div>
    <label class="text-white/70 text-sm">Student Name</label>
    <input name="student_name" placeholder="Enter name"
      class="mt-1 p-3 w-full rounded-lg bg-white/10 text-white border border-white/20 
             placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-purple-500">
  </div>

  <!-- Book Select -->
  <div>
    <label class="text-white/70 text-sm">Select Book</label>
    <select name="book_id"
      class="mt-1 p-3 w-full rounded-lg bg-white/10 text-white border border-white/20 
             backdrop-blur-md focus:outline-none focus:ring-2 focus:ring-purple-500">

      <% books.forEach(book => { %>
        <option value="<%= book.id %>" class="bg-[#0f172a] text-white">
          <%= book.book_name %> (Available: <%= book.quantity %>)
        </option>
      <% }) %>

    </select>
  </div>

  <!-- Quantity -->
  <div>
    <label class="text-white/70 text-sm">Quantity</label>
    <input name="quantity" type="number" min="1" value="1"
      class="mt-1 p-3 w-full rounded-lg bg-white/10 text-white border border-white/20 
             focus:outline-none focus:ring-2 focus:ring-purple-500">
  </div>

  <!-- 📅 Due Date -->
  <div>
    <label class="text-white/70 text-sm">Due Date</label>
    <input name="due_date" type="date"
      class="mt-1 p-3 w-full rounded-lg bg-white/10 text-white border border-white/20 
             focus:outline-none focus:ring-2 focus:ring-blue-500">
  </div>

  <!-- Button -->
  <button
    class="col-span-4 bg-gradient-to-r from-purple-500 to-blue-500 
           text-white p-3 rounded-xl hover:scale-105 transform transition duration-300 shadow-lg">
    Issue Book
  </button>

</form>

<!-- Issued Books -->
<div class="bg-white/10 backdrop-blur-xl border border-white/20 
            p-6 rounded-2xl shadow-xl">

  <h2 class="text-xl font-bold mb-4 text-white">Issued Books</h2>

  <table class="w-full text-left text-white">

    <tr class="bg-gradient-to-r from-purple-500/30 to-blue-500/30">
      <th class="p-3">Student</th>
      <th class="p-3">Book Name</th>
      <th class="p-3">Qty</th>
      <th class="p-3">Issued</th>
      <th class="p-3">Due</th>
      <th class="p-3">Action</th>
    </tr>

    <% issued.forEach(item => { %>
    <tr class="border-b border-white/10 hover:bg-white/5 transition">

      <td class="p-3"><%= item.student_name %></td>

      <td class="p-3"><%= item.book_name %></td>

      <td class="p-3"><%= item.quantity %></td>

      <!-- Issue Date -->
      <td class="p-3 text-white/70">
        <%= new Date(item.issue_date).toLocaleDateString('en-IN') %>
      </td>

      <!-- 📅 Due Date -->
      <td class="p-3 text-yellow-300 font-semibold">
        <%= item.due_date ? new Date(item.due_date).toLocaleDateString('en-IN') : '-' %>
      </td>

      <td class="p-3">
        <a href="/issue/return/<%= item.id %>"
           class="bg-green-500 px-3 py-1 rounded-lg hover:bg-green-600 transition shadow">
          Return
        </a>
      </td>

    </tr>
    <% }) %>

  </table>

</div>

</div>
</div>

<!-- 🔥 DARK DROPDOWN FIX -->
<style>
  select {
    background-color: rgba(255,255,255,0.1);
    color: white;
  }

  option {
    background-color: #0f172a;
    color: white;
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(1);
  }
</style>

<%- include('partials/footer') %>