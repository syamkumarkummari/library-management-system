<%- include('partials/header') %>
<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full text-white">

<!-- HEADER + BUTTON -->
<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">👥 All Users</h1>

  <a href="/admin/users/add"
     class="bg-gradient-to-r from-purple-500 to-blue-500 
            px-5 py-2 rounded-lg shadow hover:scale-105 transition">
    ➕ Add User
  </a>
</div>

<!-- TABLE -->
<div class="bg-white/10 rounded-2xl overflow-hidden">

<table class="w-full table-fixed text-white">

<thead class="bg-gradient-to-r from-purple-500/30 to-blue-500/30">
<tr class="text-left">
  <th class="p-4 w-[20%]">Name</th>
  <th class="w-[15%]">Reg No</th>
  <th class="w-[10%]">Dept</th>
  <th class="w-[10%]">Year</th>
  <th class="w-[15%]">Username</th>
  <th class="w-[30%] text-center">Actions</th>
</tr>
</thead>

<tbody>

<% users.forEach(user => { %>
<tr class="border-b border-white/10 hover:bg-white/5">

<td class="p-4"><%= user.full_name %></td>
<td><%= user.reg_no %></td>
<td><%= user.dept %></td>
<td><%= user.year %></td>
<td><%= user.username %></td>

<td class="text-center space-x-2">

<a href="/admin/users/edit/<%= user.id %>"
   class="bg-blue-500 px-3 py-1 rounded hover:bg-blue-600">
   Edit
</a>

<a href="/admin/users/delete/<%= user.id %>"
   class="bg-red-500 px-3 py-1 rounded hover:bg-red-600">
   Delete
</a>

<a href="/admin/users/activity/<%= user.username %>"
   class="bg-purple-500 px-3 py-1 rounded hover:bg-purple-600">
   Activity
</a>

</td>

</tr>
<% }) %>

</tbody>
</table>

</div>