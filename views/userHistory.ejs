<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen 
     bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<h1 class="text-3xl font-bold mb-8">
  📜 Borrow History
</h1>

<div class="bg-white/10 backdrop-blur-xl border border-white/20 
            rounded-2xl shadow-xl overflow-hidden">

<table class="w-full text-white">

<thead class="bg-gradient-to-r from-purple-500/30 to-blue-500/30">
<tr>
  <th class="p-4 text-left">Book</th>
  <th class="p-4 text-center">Issued</th>
  <th class="p-4 text-center">Returned</th>
  <th class="p-4 text-center">Fine</th>
</tr>
</thead>

<tbody>

<% history.forEach(item => { %>

<tr class="border-b border-white/10 hover:bg-white/5">

<td class="p-4"><%= item.book_name %></td>

<td class="p-4 text-center">
<%= new Date(item.issue_date).toLocaleDateString('en-IN') %>
</td>

<td class="p-4 text-center">
<%= new Date(item.return_date).toLocaleDateString('en-IN') %>
</td>

<td class="p-4 text-center">

<% 
let fine = 0;
if(item.due_date && item.return_date){
  const due = new Date(item.due_date);
  const ret = new Date(item.return_date);
  const diff = Math.ceil((ret - due) / (1000 * 60 * 60 * 24));
  fine = diff > 0 ? diff * 10 : 0;
}
%>

<span class="<%= fine > 0 ? 'text-red-400' : 'text-green-400' %> font-semibold">
₹ <%= fine %>
</span>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>
</div>

<%- include('partials/footer') %>