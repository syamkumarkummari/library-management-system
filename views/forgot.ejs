<!DOCTYPE html>
<html>
<head>
  <title>Forgot Password</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      margin: 0;
      height: 100vh;
      overflow: hidden;
    }

    .bg-animated {
      position: fixed;
      width: 100%;
      height: 100%;
      background: url('https://images.unsplash.com/photo-1512820790803-83ca734da794') no-repeat center center/cover;
      animation: zoomMove 20s ease-in-out infinite alternate;
      z-index: -2;
    }

    @keyframes zoomMove {
      0% { transform: scale(1); }
      100% { transform: scale(1.2); }
    }

    .overlay {
      position: fixed;
      width: 100%;
      height: 100%;
      background: rgba(15, 23, 42, 0.7);
      z-index: -1;
    }
  </style>
</head>

<body class="flex items-center justify-center">

<div class="bg-animated"></div>
<div class="overlay"></div>

<form action="/forgot" method="POST"
      class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl w-80 text-center text-white">

  <h2 class="text-2xl font-bold mb-5">Reset Password</h2>

  <input name="username" placeholder="Enter Username"
         class="w-full p-2 mb-4 rounded bg-white/20 placeholder-white/60 outline-none">

  <input name="new_password" type="password" placeholder="New Password"
         class="w-full p-2 mb-4 rounded bg-white/20 placeholder-white/60 outline-none">

  <button
    class="w-full p-2 rounded font-semibold
           bg-gradient-to-r from-purple-500 to-blue-500
           hover:from-purple-600 hover:to-blue-600 transition">
    Reset Password
  </button>

  <p class="mt-4 text-sm">
    Back to
    <a href="/" class="text-blue-400 hover:underline">Login</a>
  </p>

</form>

</body>
</html>