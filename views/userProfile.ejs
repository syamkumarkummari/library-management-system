<%- include('partials/header') %>

<div class="flex">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen 
     bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<h1 class="text-3xl font-bold mb-8 flex items-center gap-2">
  👤 My Profile
</h1>

<!-- 🔥 PROFILE HEADER (NO IMAGE) -->
<div class="flex items-center justify-between mb-10">

  <div>
    <h2 class="text-2xl font-bold">
      <%= user.full_name || user.username %>
    </h2>
    <p class="text-white/60">
      <%= user.dept || 'Department not set' %>
    </p>
  </div>

  <!-- ✏️ EDIT BUTTON -->
  <a href="/user/edit-profile"
     class="bg-blue-500 px-4 py-2 rounded-lg hover:bg-blue-600 transition shadow">
    Edit Profile
  </a>

</div>

<!-- 🔥 MAIN GRID -->
<div class="grid grid-cols-2 gap-8">

<!-- 📄 PROFILE INFO -->
<div class="bg-white/10 backdrop-blur-xl border border-white/20 
            rounded-2xl p-6 shadow-lg">

<h2 class="text-xl font-bold mb-4">📄 Student Information</h2>

<div class="space-y-3 text-white/90">

<p><span class="text-white/60">Full Name:</span> <%= user.full_name || '-' %></p>
<p><span class="text-white/60">Register No:</span> <%= user.reg_no || '-' %></p>
<p><span class="text-white/60">Department:</span> <%= user.dept || '-' %></p>
<p><span class="text-white/60">Academic Year:</span> <%= user.year || '-' %></p>
<p><span class="text-white/60">Username:</span> <%= user.username %></p>

</div>

</div>

<!-- 🔐 CHANGE PASSWORD -->
<div class="bg-white/10 backdrop-blur-xl border border-white/20 
            rounded-2xl p-6 shadow-lg">

<h2 class="text-xl font-bold mb-4">🔐 Change Password</h2>

<form action="/user/change-password" method="POST" class="space-y-4">

<input type="password" name="old_password" placeholder="Old Password" required
class="w-full p-3 rounded-lg bg-white/10 border border-white/20 text-white 
       placeholder-white/60 focus:ring-2 focus:ring-purple-500">

<input type="password" name="new_password" placeholder="New Password" required
class="w-full p-3 rounded-lg bg-white/10 border border-white/20 text-white 
       placeholder-white/60 focus:ring-2 focus:ring-blue-500">

<button
  class="w-full bg-gradient-to-r from-purple-500 to-blue-500 
         p-3 rounded-lg hover:scale-105 transition shadow-lg">
  Update Password
</button>

</form>

</div>

</div>

</div>
</div>

<%- include('partials/footer') %>