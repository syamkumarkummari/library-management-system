<%- include('partials/header') %>

<div class="flex relative z-10">
<%- include('partials/sidebar') %>

<div class="ml-64 p-8 w-full min-h-screen 
     bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#1e3a8a] text-white">

<h1 class="text-3xl font-bold mb-8">✏️ Edit Profile</h1>

<div class="max-w-2xl mx-auto bg-white/10 backdrop-blur-xl border border-white/20 
            rounded-2xl p-6 shadow-lg">

<form action="/user/edit-profile" method="POST" class="space-y-5">

  <!-- FULL NAME -->
  <div class="grid grid-cols-3 items-center gap-4">
    <label class="text-white/70 text-right">Full Name</label>
    <input name="full_name" value="<%= user.full_name %>" required
      class="col-span-2 p-3 rounded bg-white/10 border border-white/20 text-white focus:ring-2 focus:ring-purple-500">
  </div>

  <!-- REGISTER NUMBER -->
  <div class="grid grid-cols-3 items-center gap-4">
    <label class="text-white/70 text-right">Register Number</label>
    <input name="reg_no" value="<%= user.reg_no %>" required
      class="col-span-2 p-3 rounded bg-white/10 border border-white/20 text-white focus:ring-2 focus:ring-blue-500">
  </div>

  <!-- DEPARTMENT -->
  <div class="grid grid-cols-3 items-center gap-4">
    <label class="text-white/70 text-right">Department</label>
    <input name="dept" value="<%= user.dept %>" required
      class="col-span-2 p-3 rounded bg-white/10 border border-white/20 text-white focus:ring-2 focus:ring-purple-500">
  </div>

  <!-- ACADEMIC YEAR -->
  <div class="grid grid-cols-3 items-center gap-4">
    <label class="text-white/70 text-right">Academic Year</label>
    <input name="year" value="<%= user.year %>" required
      class="col-span-2 p-3 rounded bg-white/10 border border-white/20 text-white focus:ring-2 focus:ring-blue-500">
  </div>

  <!-- BUTTON -->
  <div class="text-center pt-4">
    <button class="w-full bg-gradient-to-r from-purple-500 to-blue-500 
                   p-3 rounded-lg hover:scale-105 transition shadow-lg">
      Save Changes
    </button>
  </div>

</form>

</div>

</div>
</div>

<%- include('partials/footer') %>